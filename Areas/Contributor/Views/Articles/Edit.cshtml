@model rhupolomolok.Models.Article

<div class="container mt-4" style="max-width: 900px;">

    <h3>Edit Article</h3>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card mb-4">
        <div class="card-body">

            <form asp-area="Contributor"
                  asp-controller="Articles"
                  asp-action="Edit"
                  method="post">

                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <!-- TITLE -->
                <div class="mb-3">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <!-- CATEGORY DROPDOWN -->
                <div class="mb-3">
                    <label class="form-label">Category</label>

                    <select asp-for="CategoryId"
                            class="form-control"
                            asp-items="@(ViewBag.Categories != null
                                                            ? new SelectList(ViewBag.Categories, "Id", "Name")
                                                            : new List<SelectListItem>())">
                    </select>

                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>

                <!-- CONTENT -->
                <div class="mb-3">
                    <label asp-for="Content" class="form-label"></label>
                    <textarea asp-for="Content" class="form-control" rows="8"></textarea>
                    <span asp-validation-for="Content" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary">Save Changes</button>
            </form>

        </div>
    </div>

    <!-- MEDIA SECTION -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Media Files</h5>
        </div>

        <div class="card-body">

            <!-- EXISTING MEDIA -->
            <div class="row">
                @foreach (var media in ViewBag.Media)
                {
                    <div class="col-md-4 mb-3" id="media-card-@media.Id">
                        <div class="card shadow-sm">

                            @if (media.MediaType == "Image")
                            {
                                <img src="@media.FilePath" class="card-img-top" style="height: 180px; object-fit: cover;" />
                            }
                            else if (media.MediaType == "Video")
                            {
                                <video class="w-100" height="180" controls>
                                    <source src="@media.FilePath" type="video/mp4" />
                                </video>
                            }

                            <div class="card-body p-2">
                                <div class="d-flex justify-content-between align-items-center">
                                    <small class="text-muted">@media.MediaType</small>
                                    <button class="btn btn-sm btn-danger delete-media-btn"
                                            data-id="@media.Id">
                                        Delete
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <hr />

            <!-- UPLOAD MORE MEDIA -->
            <h6>Upload More Media</h6>

            <form asp-area="Contributor"
                  asp-controller="Articles"
                  asp-action="UploadMedia"
                  method="post"
                  enctype="multipart/form-data">

                @Html.AntiForgeryToken()
                <input type="hidden" name="articleId" value="@Model.Id" />

                <div class="mb-3">
                    <label class="form-label">Add Images (JPG only, max 3 total)</label>
                    <input type="file"
                           name="ImageFiles[]"
                           accept=".jpg"
                           multiple
                           class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Add Video (MP4 only, max 1)</label>
                    <input type="file"
                           name="VideoFile"
                           accept="video/mp4"
                           class="form-control" />
                </div>

                <button type="submit" class="btn btn-secondary">Upload Media</button>
            </form>

        </div>
    </div>


</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        document.querySelectorAll(".delete-media-btn").forEach(btn => {

            btn.addEventListener("click", function () {

                if (!confirm("Are you sure you want to delete this media file?"))
                    return;

                const mediaId = this.getAttribute("data-id");

                fetch(`/Contributor/Articles/DeleteMedia/${mediaId}`, {
                    method: "POST",
                    headers: {
                        "RequestVerificationToken":
                            document.querySelector("input[name='__RequestVerificationToken']").value
                    }
                })
                .then(response => {
                    if (response.ok) {
                        const card = document.getElementById(`media-card-${mediaId}`);
                        card.style.transition = "opacity 0.4s";
                        card.style.opacity = "0";
                        setTimeout(() => card.remove(), 400);
                    }
                });
            });
        });

    });
</script>
