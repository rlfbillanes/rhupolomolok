@model rhupolomolok.Models.Article

<div class="container py-4" style="max-width: 1000px;">

    <div class="mb-4">
        <h3 class="fw-bold">Edit Article</h3>
        <p class="text-muted mb-0">Update your article details or manage media files.</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- ARTICLE FORM -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4">

            <form asp-area="Contributor"
                  asp-controller="Articles"
                  asp-action="Edit"
                  method="post">

                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <!-- TITLE -->
                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-semibold"></label>
                    <input asp-for="Title" class="form-control form-control-lg" />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>

                <!-- CATEGORY -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">Category</label>
                    <select asp-for="CategoryId"
                            class="form-select form-select-lg"
                            asp-items="@(ViewBag.Categories != null
                                                            ? new SelectList(ViewBag.Categories, "Id", "Name")
                                                            : new List<SelectListItem>())">
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                </div>

                <!-- CONTENT -->
                <div class="mb-3">
                    <label asp-for="Content" class="form-label fw-semibold"></label>
                    <textarea asp-for="Content" class="form-control" rows="8"></textarea>
                    <span asp-validation-for="Content" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-lg w-100">Save Changes</button>

            </form>

        </div>
    </div>

    <!-- MEDIA SECTION -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white py-3">
            <h5 class="fw-bold mb-0">Media Files</h5>
        </div>

        <div class="card-body p-4">

            <div class="row g-3">
                @foreach (var media in ViewBag.Media)
                {
                    <div class="col-md-4" id="media-card-@media.Id">
                        <div class="card shadow-sm border-0">

                            @if (media.MediaType == "Image")
                            {
                                <img src="@media.FilePath" class="card-img-top" style="height: 180px; object-fit: cover;" />
                            }
                            else if (media.MediaType == "Video")
                            {
                                <video class="w-100" height="180" controls>
                                    <source src="@media.FilePath" type="video/mp4" />
                                </video>
                            }

                            <div class="card-body text-center p-2">
                                <button class="btn btn-outline-danger btn-sm delete-media-btn"
                                        data-id="@media.Id">
                                    Delete
                                </button>
                            </div>

                        </div>
                    </div>
                }
            </div>

            <hr class="my-4" />

            <!-- UPLOAD MORE MEDIA -->
            <h5 class="fw-bold mb-3">Upload More Media</h5>

            <form asp-area="Contributor"
                  asp-controller="Articles"
                  asp-action="UploadMedia"
                  method="post"
                  enctype="multipart/form-data">

                @Html.AntiForgeryToken()
                <input type="hidden" name="articleId" value="@Model.Id" />

                <div class="mb-3">
                    <label class="form-label fw-semibold">Add Images (JPG only, max 3 total)</label>
                    <input type="file" name="ImageFiles" accept=".jpg" multiple class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Add Video (MP4 only, max 1)</label>
                    <input type="file" name="VideoFile" accept="video/mp4" class="form-control" />
                </div>

                <button type="submit" class="btn btn-secondary w-100">Upload Media</button>

            </form>

        </div>
    </div>

</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        document.querySelectorAll(".delete-media-btn").forEach(btn => {
            btn.addEventListener("click", function () {
                if (!confirm("Are you sure you want to delete this media file?")) return;

                const mediaId = this.getAttribute("data-id");

                fetch(`/Contributor/Articles/DeleteMedia/${mediaId}`, {
                    method: "POST",
                    headers: {
                        "RequestVerificationToken":
                            document.querySelector("input[name='__RequestVerificationToken']").value
                    }
                })
                .then(response => {
                    if (response.ok) {
                        const card = document.getElementById(`media-card-${mediaId}`);
                        card.style.opacity = "0";
                        setTimeout(() => card.remove(), 300);
                    }
                });
            });
        });
    });
</script>
